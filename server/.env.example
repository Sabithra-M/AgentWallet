PORT=5000
NODE_ENV=development

# PostgreSQL (Neon)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# Frontend URL (used to build password-reset links)
CLIENT_APP_URL=http://localhost:5173

# Email (required — sendMail throws if any of these are missing).
# Works with any SMTP provider: Gmail (smtp.gmail.com, port 587, an App
# Password — not your regular password), Resend (smtp.resend.com, port 465
# or 587, username "resend", password = your Resend API key), Mailtrap, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AgentWallet <no-reply@agentwallet.dev>

# Google Sign-In (Firebase Admin SDK) — from Firebase Console > Project
# Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# AI Assistant (Gemini) — from https://aistudio.google.com/apikey. Without
# this, the AI Assistant chat endpoint responds with a 500 explaining it's
# not configured; every other feature works fine without it.
GEMINI_API_KEY=
